STEP 4: Create App 2 — Student Info App
bashcd ~
mkdir app2
cd app2
bashcat > main.py << 'EOF'
from flask import Flask
app = Flask(__name__)

@app.route('/')
def home():
    return '<h1>Student Web App</h1>'

@app.route('/info')
def info():
    return '''
    <h1>Student Information</h1>
    <p>Name: Your Name</p>
    <p>Class: TY Computer Science</p>
    <p>College: Your College Name</p>
    '''

@app.route('/hello/<name>')
def hello(name):
    return f'<h1>Hello, {name}! Welcome to my App.</h1>'

if __name__ == '__main__':
    app.run()
EOF

